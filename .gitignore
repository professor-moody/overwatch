# Local control baselines cached by `npm run prompt-eval` (machine/model-specific).
eval-baselines/

# dashboard-next: Vite handles transpilation; tsc is typecheck-only.
# Guard against accidental emit if someone runs `tsc -p src/dashboard-next`.
src/dashboard-next/**/*.js
src/dashboard-next/tsconfig.tsbuildinfo
# but keep config files that legitimately ship as .js (postcss)
!src/dashboard-next/postcss.config.js

# Local MCP client config — absolute paths are machine-specific.
.mcp.json
.overwatch-mcp-token
.claude/settings.json
.claude/scheduled_tasks.lock

# Local code-graph tool artifacts (regenerable, machine-specific, large).
.codegraphy/

# Real engagement files are operator-local; the repo ships engagement.example.json
# as the template. Keep actual engagements out of version control.
engagements/
