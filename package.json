{
  "name": "overwatch-mcp-server",
  "version": "0.1.0",
  "description": "Offensive security engagement orchestrator - MCP server with graph-based state management",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "overwatch-mcp-tape": "dist/bin/overwatch-mcp-tape.js"
  },
  "scripts": {
    "build": "tsc && npx vite build --config src/dashboard-next/vite.config.ts",
    "build:dashboard-next": "npx vite build --config src/dashboard-next/vite.config.ts",
    "build:pages": "GITHUB_PAGES=true npx vite build --config src/dashboard-next/vite.config.ts && cp dist/dashboard-next/index.html dist/dashboard-next/404.html",
    "dev:dashboard-next": "npx vite --config src/dashboard-next/vite.config.ts",
    "demo:dashboard": "npx tsx scripts/demo-dashboard.ts",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "npm run test:source",
    "test:source": "vitest run",
    "test:integration:stdio": "npm run build && vitest run --config vitest.integration-stdio.config.ts",
    "test:integration:http": "npm run build && vitest run --config vitest.integration-http.config.ts",
    "check:dist": "git diff --exit-code -- dist",
    "verify": "npm run test:source && npm run test:integration:stdio && npm run test:integration:http && npm run check:dist",
    "retrospective": "node dist/cli/retrospective.js",
    "lab:smoke": "node dist/cli/lab-smoke.js",
    "hooks:smoke": "node scripts/smoke-claude-hooks.mjs",
    "docs:serve": "mkdocs serve",
    "docs:deploy": "mkdocs gh-deploy --remote-name sandbox --force"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/pg": "^8.20.0",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.7.2",
    "graphology-communities-louvain": "2.0.2",
    "graphology-shortest-path": "2.1.0",
    "graphology-types": "0.24.8",
    "lucide-react": "^1.8.0",
    "pg": "^8.20.0",
    "puppeteer-core": "^24.43.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.16.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^14.0.0",
    "ws": "^8.21.0",
    "zod": "3.25.76",
    "zustand": "^5.0.12"
  },
  "optionalDependencies": {
    "node-pty": "1.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/express": "5.0.6",
    "@types/node": "22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "10.0.0",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "autoprefixer": "^10.5.0",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "postcss": "^8.5.10",
    "sigma": "^3.0.2",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite": "^6.4.2",
    "vitest": "4.1.0"
  },
  "overrides": {
    "hono": "4.12.18"
  }
}
