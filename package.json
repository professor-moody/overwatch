{
  "name": "overwatch-mcp-server",
  "version": "0.2.0",
  "description": "Offensive security engagement orchestrator - MCP server with graph-based state management",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/**",
    "engagement-templates/**",
    "skills/**",
    ".claude/hooks/**",
    ".claude/settings.example.json",
    ".mcp.example.json",
    ".mcp.http.example.json",
    "scripts/setup.mjs",
    "scripts/doctor.mjs",
    "scripts/node-runtime.mjs",
    "scripts/node-runtime.d.mts",
    "scripts/engagement-artifacts.mjs",
    "scripts/check-package.mjs",
    "scripts/check-release.mjs",
    "scripts/build-fingerprint.mjs",
    "scripts/write-build-info.mjs",
    "scripts/ensure-fresh-build.mjs",
    "scripts/runtime-profile.mjs",
    "scripts/process-identity.mjs",
    "scripts/daemon-lifecycle.mjs",
    "scripts/upgrade-state-lease.mjs",
    "scripts/lifecycle-smoke.mjs",
    "engagement.example.json",
    "README.md",
    "CHANGELOG.md",
    "docs/compatibility.md",
    "docs/reference/compatibility-manifest.json",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20 <21 || >=22 <23 || >=24 <25"
  },
  "bin": {
    "overwatch-mcp-tape": "dist/bin/overwatch-mcp-tape.js",
    "overwatch": "dist/cli/operator-cli.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json && tsc -p src/dashboard-next/tsconfig.json --noEmit && npx vite build --config src/dashboard-next/vite.config.ts",
    "postbuild": "node scripts/write-build-info.mjs",
    "build:dashboard-next": "npx vite build --config src/dashboard-next/vite.config.ts",
    "build:pages": "GITHUB_PAGES=true npx vite build --config src/dashboard-next/vite.config.ts && cp tmp/dashboard-pages/index.html tmp/dashboard-pages/404.html",
    "dev:dashboard-next": "npx vite --config src/dashboard-next/vite.config.ts",
    "demo:dashboard": "npx tsx scripts/demo-dashboard.ts",
    "demo:daemon": "npx tsx scripts/demo-daemon.ts",
    "report:qa": "npx tsx scripts/report-qa.ts",
    "prompt-eval": "npx tsx src/cli/prompt-eval.ts",
    "orch-eval": "npx tsx src/cli/orch-eval.ts",
    "benchmark:dashboard": "npx tsx scripts/benchmark-dashboard-projection.ts",
    "benchmark:agents": "npx vitest run --config vitest.scale-soak.config.ts src/services/__tests__/agent-scale-soak.test.ts --reporter=verbose",
    "gen:docs": "npx tsx scripts/gen-public-inventories.ts",
    "check:docs": "npx tsx scripts/gen-public-inventories.ts --check && npm run check:docs:semantic",
    "check:docs:semantic": "node scripts/check-docs-semantics.mjs",
    "gen:dashboard-api": "npx tsx scripts/gen-dashboard-api.ts",
    "check:dashboard-api": "npx tsx scripts/gen-dashboard-api.ts --check",
    "gen:checkpoint-key": "npx tsx scripts/gen-checkpoint-key.ts",
    "setup": "node scripts/setup.mjs",
    "setup:stdio": "node scripts/setup.mjs --stdio",
    "doctor": "node scripts/doctor.mjs",
    "start": "node scripts/daemon-lifecycle.mjs run",
    "start:daemon": "node scripts/daemon-lifecycle.mjs run",
    "start:stdio": "node scripts/daemon-lifecycle.mjs run-stdio",
    "daemon": "node scripts/daemon-lifecycle.mjs",
    "daemon:start": "node scripts/daemon-lifecycle.mjs start",
    "daemon:status": "node scripts/daemon-lifecycle.mjs status",
    "daemon:stop": "node scripts/daemon-lifecycle.mjs stop",
    "daemon:restart": "node scripts/daemon-lifecycle.mjs restart",
    "upgrade": "node scripts/daemon-lifecycle.mjs upgrade",
    "dev": "tsc --watch",
    "test": "npm run test:source",
    "test:source": "vitest run",
    "test:dashboard-dom": "vitest run --config vitest.dashboard-dom.config.ts",
    "test:journeys": "vitest run --config vitest.journeys.config.ts",
    "test:scale-soak": "vitest run --config vitest.scale-soak.config.ts",
    "test:scale-soak:extended": "OVERWATCH_SOAK_PROFILE=extended vitest run --config vitest.scale-soak.config.ts",
    "test:browser:server": "node --import tsx scripts/browser-journey-server.ts",
    "test:browser": "node scripts/run-browser-tests.mjs",
    "test:integration:stdio": "npm run build && vitest run --config vitest.integration-stdio.config.ts",
    "test:integration:http": "npm run build && vitest run --config vitest.integration-http.config.ts",
    "test:lifecycle": "node scripts/lifecycle-smoke.mjs",
    "check:dist": "git diff --exit-code -- dist",
    "check:release": "node scripts/check-release.mjs",
    "check:package": "node scripts/check-package.mjs",
    "verify": "npm run check:docs && npm run check:dashboard-api && npm run test:source && npm run test:dashboard-dom && npm run test:journeys && npm run test:scale-soak && npm run test:integration:stdio && npm run test:integration:http && npm run test:lifecycle && npm run check:release && npm run check:package",
    "retrospective": "node dist/cli/retrospective.js",
    "overwatch": "node dist/cli/operator-cli.js",
    "lab:smoke": "node dist/cli/lab-smoke.js",
    "hooks:smoke": "node scripts/smoke-claude-hooks.mjs",
    "docs:serve": "mkdocs serve",
    "docs:deploy": "mkdocs gh-deploy --remote-name sandbox --force"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/pg": "^8.20.0",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.7.2",
    "graphology-communities-louvain": "2.0.2",
    "graphology-layout-noverlap": "^0.4.2",
    "graphology-shortest-path": "2.1.0",
    "graphology-types": "0.24.8",
    "lucide-react": "^1.8.0",
    "pg": "^8.20.0",
    "puppeteer-core": "^24.43.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.16.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^14.0.0",
    "ws": "^8.21.0",
    "zod": "3.25.76",
    "zustand": "^5.0.12"
  },
  "optionalDependencies": {
    "node-pty": "1.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "5.0.6",
    "@types/node": "22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "10.0.0",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "autoprefixer": "^10.5.0",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "happy-dom": "^20.10.6",
    "postcss": "^8.5.10",
    "sigma": "^3.0.2",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite": "^6.4.2",
    "vitest": "4.1.0"
  },
  "overrides": {
    "hono": "^4.12.25"
  }
}
